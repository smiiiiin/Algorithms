#include <bits/stdc++.h>
using namespace std;

int N, M, T; long long result = 0;

int A[1001]; int B[1001];

vector<int> sumA; vector<int> sumB;

int main() {
    ios::sync_with_stdio(false);   cin.tie(nullptr);

    cin >> T; cin >> N; cin >> M;

    // A 누적합
    for(int y = 1; y <= N; ++y) {
        cin >> A[y];
        A[y] += A[y - 1];
    }

    // B 누적합
    for(int y = 1; y <= M; ++y) {
        cin >> B[y];
        B[y] += B[y - 1];
    }

    // A의 연속 부분합
    for(int y = 1; y <= N; ++y) {
        for(int x = 0; x < y; ++x) {
            sumA.push_back(A[y] - A[x]);
        }
    }

    // B의 연속 부분합
    for(int y = 1; y <= M; ++y) {
        for(int x = 0; x < y; ++x) {
            sumB.push_back(B[y] - B[x]);
        }
    }

    sort(sumB.begin(), sumB.end());

    for(auto v : sumA) {

        int target = T - v;

        int high = upper_bound(sumB.begin(), sumB.end(), target) ;

        int low = lower_bound(sumB.begin(), sumB.end(), target) ;

        result += (high - low);
    }

    cout << result;

    return 0;
}
