
#include <cstdio>
#include <vector>
using namespace std;

int main() {

    int n;
    scanf("%d", &n);

    vector<bool> prime(n + 1, true);
    vector<int> res;

    // 0, 1은 소수 아님
    if(n >= 0) prime[0] = false;
    if(n >= 1) prime[1] = false;

    // 에라토스테네스의 체
    for(int i = 2; i * i <= n; i++) {

        if(prime[i]) {

            for(int j = i * i; j <= n; j += i) {
                prime[j] = false;
            }
        }
    }

    // 소수 저장
    for(int i = 2; i <= n; i++) {
        if(prime[i]) {
            res.push_back(i);
        }
    }

    // 출력
    for(auto x : res) {
        printf("%d ", x);
    }

    return 0;
}
