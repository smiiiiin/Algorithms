// 백준 1644 소수의 연속합
#include <cstdio>
#include <vector>
#include <queue>
using namespace std;

int main() {
    int n;
    scanf("%d", &n);

    vector<bool> check(n + 1, true);
    vector<int> prime;

    // 0,1은 소수 아님
    if(n >= 0) check[0] = false;
    if(n >= 1) check[1] = false;

    // 에라토스테네스의 체
    for(int i = 2; i * i <= n; i++) {
        if(check[i]) {
            for(int j = i * i; j <= n; j += i) {
                check[j] = false;
            }
        }
    }

    // 소수 저장
    for(int i = 2; i <= n; i++) {
        if(check[i]) prime.push_back(i);
    }

    queue<int> q;
    int sum = 0;
    int cnt = 0;

    // 투포인터 느낌
    for(int i = 0; i < prime.size(); i++) {
        q.push(prime[i]);
        sum += prime[i];

        while(sum > n && !q.empty()) {
            sum -= q.front();
            q.pop();
        }

        if(sum == n) cnt++;
    }

    printf("%d\n", cnt);

    return 0;
}
