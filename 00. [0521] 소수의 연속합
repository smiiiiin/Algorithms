// 소수 만들기
#include <cstdio>
#include <vector>
#include <queue>
using namespace std;

int main() {
    int n;
    scanf("%d", &n);

    vector<bool> check(n + 1, true);
    vector<int> prime;

    // 0,1은 소수 아님
    if(n >= 0) check[0] = false;
    if(n >= 1) check[1] = false;

    // 에라토스테네스의 체
    for(int i = 2; i * i <= n; i++) {
        if(check[i]) {
            for(int j = i * i; j <= n; j += i) {
                check[j] = false;
            }
        }
    }

    // 소수 저장
    for(int i = 2; i <= n; i++) {
        if(check[i]) prime.push_back(i);
    }

    return 0;
}
