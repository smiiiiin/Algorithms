#include <iostream>
#include <algorithm>
using namespace std;

int n; int dp[501][501]; int sum[501];

int main() {
    ios::sync_with_stdio(false); cin.tie(nullptr);
    cin >> n;
    for(int i = 1; i <= n; i++) {

        int x; cin >> x;
        sum[i] = sum[i - 1] + x;
    }
    // len : 구간 길이
    for(int len = 1; len < n; len++) {
        // s : 시작점
        for(int s = 1; s + len <= n; s++) {
            int e = s + len; dp[s][e] = 1e9;
            // 분할 위치
            for(int m = s; m < e; m++) {
                //dp[3]= min(dp[3], dp[2]+arr[3]); 이런느낌
                dp[s][e] = min( dp[s][e],  dp[s][m] + dp[m + 1][e] + (sum[e] - sum[s - 1])
                );
            }
        }
    }

    cout << dp[1][n] << '\n';
    return 0;}
