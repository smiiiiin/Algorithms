#include <iostream>
#include <algorithm>
// 10c3
using namespace std;

int n; int dp[101][101]; int sum[101];



int main() {
    ios::sync_with_stdio(false); cin.tie(0);
    
    cin >>n; int a;
    for(int i=1;i<=n;i++){
        cin>>a;
        sum[i]=sum[i-1]+a;
    }
    
    for(int size=1;size<n;size++){
        for(int s=1;s+size<=n;s++){
            int e= s+size;
            
            dp[s][e]=1e9;
            
            for(int m=s;m<e;m++){
                dp[s][e]= min(dp[s][e], dp[s][m]+dp[m+1][e]+sum[e]-sum[s-1]);
            }
        }
    }
    
    cout<<dp[1][n];
    
    return 0;
}
