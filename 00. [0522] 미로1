#include <iostream>
#include <queue>
#include <string>
using namespace std;

const int N = 16;

int maze[N][N];
bool visited[N][N];

int dy[4] = {-1, 1, 0, 0};
int dx[4] = {0, 0, -1, 1};

bool bfs(int sy, int sx) {
    queue<pair<int, int>> q;

    q.push({sy, sx});
    visited[sy][sx] = true;

    while (!q.empty()) {
        int y = q.front().first;
        int x = q.front().second;
        q.pop();

        if (maze[y][x] == 3)
            return true;

        for (int i = 0; i < 4; i++) {
            int ny = y + dy[i];
            int nx = x + dx[i];

            // 범위 체크
            if (ny < 0 || nx < 0 || ny >= N || nx >= N)
                continue;

            // 벽 또는 방문한 곳
            if (maze[ny][nx] == 1 || visited[ny][nx])
                continue;

            visited[ny][nx] = true;
            q.push({ny, nx});
        }
    }
    // break; 와 달리 (반복문종결) return은 함수 종결
    return false;
}

int main() {

    for (int tc = 1; tc <= 10; tc++) {

        int test_case;
        cin >> test_case;

        int sy = 0, sx = 0;

        // 초기화
        for (int i = 0; i < N; i++) {
            for (int j = 0; j < N; j++) {
                visited[i][j] = false;
            }
        }

        for (int i = 0; i < N; i++) {
            string s;
            cin >> s;

            for (int j = 0; j < N; j++) {
                maze[i][j] = s[j] - '0';

                if (maze[i][j] == 2) {
                    sy = i;
                    sx = j;
                }
            }
        }

        cout << "#" << tc << " " << bfs(sy, sx) << '\n';
    }
}
