//https://www.acmicpc.net/submit/2146/41266419 참고하기


#include <iostream>
#include <queue>
#include <cstring>
using namespace std;

int n;
int map[100][100];
bool visited[100][100];
int dy[4] = {-1,1,0,0};
int dx[4] = {0,0,-1,1};

// 1. 섬에 번호 붙이기
void labelIsland(int y, int x, int num) {
    queue<pair<int,int>> q;
    q.push({y,x});
    visited[y][x] = true;
    map[y][x] = num;

    while(!q.empty()) {
        auto [cy, cx] = q.front(); // cy= q.front().first; cx= q.front().second;
        q.pop();

        for(int d=0; d<4; d++){
            int ny = cy + dy[d];
            int nx = cx + dx[d];

            if(ny<0 || nx<0 || ny>=n || nx>=n) continue;

            if(!visited[ny][nx] && map[ny][nx] == 1){
                visited[ny][nx] = true;
                map[ny][nx] = num;
                q.push({ny,nx});
            }
        }
    }
}

// 2. 다리 길이 찾기
int getBridge(int num){
    queue<pair<int,int>> q;

    // 시작: 해당 섬 전부 넣기
    for(int i=0;i<n;i++){
        for(int j=0;j<n;j++){
            if(map[i][j]==num){
                q.push({i,j});
                visited[i][j]=true;
            }
        }
    }

    int dist = 0;

    while(!q.empty()){
        int size = q.size();

        for(int i=0;i<size;i++){
            auto [y,x] = q.front(); 
            q.pop();

            for(int d=0; d<4; d++){
                int ny = y + dy[d];
                int nx = x + dx[d];

                if(ny<0 || nx<0 || ny>=n || nx>=n) continue;

                // 다른 섬 만남 → 끝!
                if(map[ny][nx] != 0 && map[ny][nx] != num)
                    return dist;

                // 바다만 퍼짐
                if(map[ny][nx] == 0 && !visited[ny][nx]){
                    visited[ny][nx] = true;
                    q.push({ny,nx});
                }
            }
        }
        dist++; // 한 칸 확장
    }

    return dist;
}

int main(){
    cin >> n;

    for(int i=0;i<n;i++){
        for(int j=0;j<n;j++){
            scanf("%1d", &map[i][j]);
        }
    }

    // 섬 번호 붙이기
    int num = 0;
    for(int i=0;i<n;i++){
        for(int j=0;j<n;j++){
            if(map[i][j]==1 && !visited[i][j]){
                labelIsland(i,j,++num);
            }
        }
    }

    int ans = 1e9;

    // 각 섬마다 다리 찾기
    for(int i=1;i<=num;i++){
        memset(visited, false, sizeof(visited));
        ans = min(ans, getBridge(i));
    }

    cout << ans;
}

