#include <iostream>
#include <vector>
using namespace std;

int main() {
    int T;
    cin >> T;

    for(int t = 1; t <= T; t++) {
        int n;
        cin >> n;

        vector<int> arr(n);
        for(int i = 0; i < n; i++) {
            cin >> arr[i];
        }

        long long profit = 0;
        int max_val = 0;

        for(int i = n - 1; i >= 0; i--) {
            if(arr[i] > max_val) {
                max_val = arr[i];
            } else {
                profit += (max_val - arr[i]);
            }
        }

        cout << "#" << t << " " << profit << "\n";
    }

    return 0;
}
