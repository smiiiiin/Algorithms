#include <iostream>
#include <vector>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    for (int tc = 1; tc <= T; tc++) {

        int n, m;
        cin >> n >> m;

        vector<vector<int>> arr(n, vector<int>(n));

        // 입력
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                cin >> arr[i][j];
            }
        }

        int maxSum = 0;

        // m x m 탐색
        for (int i = 0; i <= n - m; i++) {
            for (int j = 0; j <= n - m; j++) {

                int sum = 0;

                for (int x = 0; x < m; x++) {
                    for (int y = 0; y < m; y++) {
                        sum += arr[i + x][j + y];
                    }
                }

                if (sum > maxSum) {
                    maxSum = sum;
                }
            }
        }

        cout << "#" << tc << " " << maxSum << '\n';
    }

    return 0;
}
