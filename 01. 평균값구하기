#include <iostream>
#include <cmath>
using namespace std;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int T;
    cin >> T;

    for(int tc = 1; tc <= T; tc++) {

        int x;
        

        int sum = 0;

        for(int i = 0; i < 10; i++) {
            cin >> x;
            sum += x;
        }

        int avg = round((double)sum / 10);

        cout << "#" << tc << " " << avg << '\n';
    }

    return 0;
}
