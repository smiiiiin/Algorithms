#include <iostream>
#include <string>
using namespace std;
 
int main() {
 
    int T;
    cin >> T;
 
    int md[13] = {0,31,28,31,30,31,30,31,31,30,31,30,31};
 
    for (int tc = 1; tc <= T; tc++) {
 
        string s;
        cin >> s;
 
        int m = stoi(s.substr(4,2));
        int d = stoi(s.substr(6,2));
 
        cout << "#" << tc << " ";
 
        if (m < 1 || m > 12 || d < 1 || d > md[m]) {
            cout << -1 << '\n';
        } else {
            cout << s.substr(0,4) << "/"
                 << s.substr(4,2) << "/"
                 << s.substr(6,2) << '\n';
        }
    }
}
